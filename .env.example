# Public site URL — required for Stripe redirects and Supabase confirmation emails
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production (Vercel): https://capilai.app

# Phase 2 — Postgres via Supabase
DATABASE_URL="postgresql://user:password@host:5432/capilai"

# Phase 2 — Supabase (auth + storage)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Phase 1 — Hair analysis AI (OpenAI Vision)
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o"
# Optional — Encore.ts backend (see backend/README.md)
NEXT_PUBLIC_ENCORE_API_URL="http://localhost:4000"

# Phase 2 — Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Optional client alias (e.g. Stripe.js / Elements later)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Dashboard endpoint signing secret (Vercel Production → Live mode whsec_…)
STRIPE_WEBHOOK_SECRET=""
# Optional extras (local CLI / rotation). All are tried when verifying signatures.
# STRIPE_WEBHOOK_SECRET_CLI=""
# STRIPE_WEBHOOK_SECRET_TEST=""
# STRIPE_WEBHOOK_SECRET_LIVE=""
# Or comma-separate several secrets in STRIPE_WEBHOOK_SECRET
# Price IDs (Dashboard Stripe → Produits → Tarifs)
# App plan "free"     → DISCOVERY
# App plan "premium"  → ESSENTIEL / ESSENTIAL (Essentiel)
# App plan "pro"      → PREMIUM (Premium)
NEXT_PUBLIC_STRIPE_PRICE_DISCOVERY_MONTHLY=""
NEXT_PUBLIC_STRIPE_PRICE_DISCOVERY_ANNUAL=""
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIEL_MONTHLY=""
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIEL_ANNUAL=""
# English alias (also supported)
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIAL_MONTHLY=""
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIAL_ANNUAL=""
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=""
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_ANNUAL=""
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_LIFETIME=""

GOOGLE_AI_API_KEY=""
